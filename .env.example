# ==========================================
# JARVIS OS — Config
# Copy file này thành .env và tuỳ chỉnh
# ==========================================
# Jarvis dùng Claude Code CLI subscription làm não.
# KHÔNG cần ANTHROPIC_API_KEY.
# MCPs cài vào Claude Code, Jarvis tự kế thừa.
# ==========================================

# Tên workspace hiển thị trên dashboard
WORKSPACE_NAME=Jarvis OS
USER_NAME=Bạn

# Working directory cho Claude CLI
# Đổi sang vault Obsidian nếu muốn Claude làm việc trong second brain
# CLAUDE_CWD=D:\My Bullet Journal

# Second Brain — Graph layer đọc 2 nguồn này
# BRAIN_PATH: thư mục brain/ trong project (mặc định)
# OBSIDIAN_VAULT_PATH: vault Bullet Journal chính
# BRAIN_PATH=D:\Project\Javis-OS\brain
OBSIDIAN_VAULT_PATH=D:\My Bullet Journal

# TTS voice mặc định
TTS_VOICE=vi-VN-HoaiMyNeural
TTS_RATE=+5%

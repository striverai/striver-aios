# Vault mặc định in-repo (dữ liệu cá nhân, không version)
vault/

# Bộ nhớ cá nhân của project brain (thay đổi mỗi phiên, không cần version)
brain/Memory/

# Dev artifact - clone Hermes để học (rất nặng, có .git riêng)
.learn/

# Cấu hình chạy dev preview cục bộ (đường dẫn theo máy, không thuộc sản phẩm)
.claude/launch.json

# Thư mục CHA chứa MỌI second brain (mô hình mới) - DỮ LIỆU CÁ NHÂN, không đẩy vào repo code.
# Backup riêng lên git repo khác (xem comment bind-mount trong docker-compose.yml).
brains/
# Bản backup brain do server tự tạo (DỮ LIỆU CÁ NHÂN) - tuyệt đối không version.
brains-backup/

# Dữ liệu CÁ NHÂN trong brain mặc định CŨ (không version): bộ nhớ, cache số liệu KD,
# automations (chứa chat_id). Cấu trúc thư mục + agent/workflow mẫu vẫn được version.
Brain Default/Memory/
Brain Default/05 - Data Cache/
Brain Default/Attachments/
Brain Default/Striver/automations.json

# Brain Default mẫu sau khi gom vào brain/ - chỉ commit cấu trúc + agent/workflow mẫu,
# KHÔNG commit dữ liệu cá nhân (bộ nhớ, cache số liệu KD, attachments, automations chứa chat_id).
brain/Brain Default/Memory/
brain/Brain Default/05 - Data Cache/
brain/Brain Default/Attachments/
brain/Brain Default/Striver/automations.json

# Skill bị tắt (chuyển vào .disabled khi tắt) - trạng thái cục bộ, không version
**/.claude/skills/.disabled/

# File rác / script cá nhân ở gốc (không thuộc sản phẩm public)
/agents
/workflows
parse_ads*.ps1

# OS
.DS_Store
Thumbs.db
desktop.ini
server/stop-last.log

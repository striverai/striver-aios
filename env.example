# ==========================================
# STRIVER AIOS - Config
# Copy file này thành .env và tuỳ chỉnh (mọi dòng để trống vẫn chạy được).
# ⚠ Tên file KHÔNG có dấu chấm đầu (env.example) là CỐ Ý: Docker Manager của
#   Hostinger tự quét file .env* trong repo khi deploy từ URL và nhập nguyên
#   nội dung (kể cả dòng chú thích "#") vào ô Environment → báo đỏ
#   "Invalid variable name". Ô Environment trên Hostinger chỉ cần DOMAIN_NAME.
# ==========================================
# Striver dùng Claude Code CLI subscription làm não.
# KHÔNG cần ANTHROPIC_API_KEY. MCPs cài vào Claude Code, Striver tự kế thừa.
# ==========================================

# Tên workspace hiển thị trên dashboard
WORKSPACE_NAME=Striver AIOS
USER_NAME=Bạn

# --- Mạng (Docker/systemd tự đặt; máy cá nhân để mặc định loopback) ---
# AIOS_HOST=127.0.0.1     # 0.0.0.0 = nghe mọi nơi (public). Chạy localhost rồi expose qua tunnel?
# AIOS_PORT=7777          #   → đặt AIOS_REQUIRE_LOGIN=1 để bắt buộc đăng nhập.

# --- Bảo mật khi chạy PUBLIC (Claude chạy full quyền → BẮT BUỘC có tài khoản) ---
# Mặc định: bind KHÔNG phải loopback → tự bật bắt buộc đăng nhập. Ép tay: 1 = bật, 0 = tắt.
# AIOS_REQUIRE_LOGIN=1
# Tạo sẵn admin lúc deploy (KHỎI cần MÃ THIẾT LẬP từ log): đặt 2 dòng dưới rồi đăng nhập bằng nó.
# Bỏ trống → lần đầu mở app phải nhập MÃ THIẾT LẬP (in trong log server) để tạo tài khoản.
# AIOS_ADMIN_USER=admin
# AIOS_ADMIN_PASSWORD=doi-mat-khau-manh-o-day
# Cookie Secure: mặc định TẮT (chạy được cả HTTP lẫn HTTPS). Chỉ bật khi CHẮC CHẮN HTTPS
# đầu-cuối (vd domain riêng có SSL) - bật khi proxy chạy HTTP sẽ KẸT vòng đăng nhập.
# (Dùng docker-compose.https.yml + đặt Tên miền riêng trong ⚙ Cài đặt thì KHỎI cần dòng này -
#  server tự bật Secure khi truy cập đúng tên miền qua HTTPS.)
# AIOS_SECURE_COOKIE=1

# --- Tên miền riêng + HTTPS ---
# KHÔNG đặt ở đây nữa. Bật Caddy (docker-compose.https.yml) rồi nhập tên miền trong app:
#   ⚙ Cài đặt → Tên miền riêng. Xem DEPLOY.md mục "🔒 HTTPS tự động".

# --- Cập nhật 1-click trong UI (Docker) ---
# Nút "Cập nhật ngay" (trang Tổng quan) gọi Watchtower kèm token này. Mặc định 'striver-update';
# ĐỔI thành chuỗi ngẫu nhiên nếu muốn chặt hơn (đặt cùng giá trị cho cả app + service watchtower).
# WATCHTOWER_TOKEN=striver-update

# --- Thư mục làm việc của Claude CLI (nơi đọc CLAUDE.md + kế thừa MCP) ---
# Để trống = repo root.
# CLAUDE_CWD=/app

# --- Second Brain - Graph layer đọc 2 nguồn này ---
# Để trống = mặc định in-repo (brain/ và vault/) → máy mới chạy được ngay.
# Trên server có vault thật thì trỏ OBSIDIAN_VAULT_PATH vào đó.
# BRAIN_PATH=/data/brain
# OBSIDIAN_VAULT_PATH=/data/vault

# --- Nơi Striver ghi state riêng (settings.json, sessions, loop config) ---
# Để trống = server/. Docker đặt /data/state (volume ghi được).
# AIOS_STATE_DIR=/data/state

# --- TTS ---
TTS_VOICE=vi-VN-HoaiMyNeural
TTS_RATE=+5%
